# ════════════════════════════════════════════════
#  SWASTHYA PORTAL — Environment Variables
#  Copy this file to .env.local and fill values
# ════════════════════════════════════════════════

# ── Supabase (REQUIRED) ──────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Speech-to-Text: FREE Whisper Options ─────────
# Pick ONE (or none — browser STT will be used automatically)
#
# OPTION A: Groq (RECOMMENDED — fastest, free, 7200s audio/day)
# Sign up FREE at https://console.groq.com (no credit card needed)
# Model used: whisper-large-v3-turbo
GROQ_API_KEY=gsk_your_groq_key_here
#
# OPTION B: Hugging Face (free, 1000 req/day)  
# Sign up FREE at https://huggingface.co → Settings → Access Tokens
# Model used: openai/whisper-large-v3
# HF_API_KEY=hf_your_hf_key_here
#
# OPTION C: No key (uses Chrome browser SpeechRecognition — zero setup)
# Just leave both keys blank. Works offline, no server needed.

# ── Intent Extraction: Google AI Studio (FREE) ───
# Sign up FREE at https://aistudio.google.com
# Free tier: 1 million tokens/day with Gemini 1.5 Flash
# Without this key: rule-based fallback is used (still works well)
GOOGLE_AI_API_KEY=your-google-ai-key-here

# ── Video Calls: Daily.co (FREE tier) ────────────
# Sign up FREE at https://dashboard.daily.co
# Free tier: 10,000 participant-minutes/month
DAILY_API_KEY=your-daily-api-key-here
NEXT_PUBLIC_DAILY_DOMAIN=your-subdomain.daily.co

# ── Optional: gTTS Python TTS Server ─────────────
# Deploy: pip install flask gtts && python gtts_server.py
# GTTS_URL=http://localhost:5001

# ── App URL ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
